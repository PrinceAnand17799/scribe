<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Interactive Onboarding</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- Persistent Header -->
    <header class="navbar bg-white shadow-sm border-bottom position-relative z-3">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold text-dark" href="#">BrandLogo</a>
        </div>
    </header>

    <!-- Main Workspace -->
    <main class="app-wrapper position-relative bg-light d-flex flex-column">
        
        <!-- BACKGROUND ANIMATIONS (Z-Index 1) -->
        <!-- The SVG container we will clone in JS to force re-animation -->
        <div id="spiral-container" class="bottom-right-arcs z-1">
            <svg viewBox="0 0 500 500" class="w-100 h-100">
                <path d="M 20 500 A 480 480 0 0 1 500 20" class="draw-arc arc-1" pathLength="100" />
                <path d="M 100 500 A 400 400 0 0 1 500 100" class="draw-arc arc-2" pathLength="100" />
                <path d="M 180 500 A 320 320 0 0 1 500 180" class="draw-arc arc-3" pathLength="100" />
                <path d="M 260 500 A 240 240 0 0 1 500 260" class="draw-arc arc-4" pathLength="100" />
            </svg>
        </div>

        <div id="hero-animations" class="shape-container z-1">
            <div class="shape half-donut"></div>
            <div class="shape quarter-circle"></div>
            <img src="https://images.unsplash.com/photo-1538356111053-748a48e1acb8?auto=format&fit=crop&w=800&h=250&q=80" alt="Elderly Couple" class="hero-image shadow-lg">
        </div>

        <!-- INTERACTIVE CONTENT AREA (Z-Index 2) -->
        <div class="container-fluid flex-grow-1 d-flex flex-column justify-content-center z-2 content-offset">
            
            <div class="row w-100">
                <div class="col-12 col-md-10 col-lg-6 col-xl-5">
                    
                    <!-- Progress Bar -->
                    <div id="progress-container" class="transition-opacity opacity-0 mb-4">
                        <div class="d-flex justify-content-between mb-1">
                            <small class="text-muted fw-bold">Setup Progress</small>
                            <small id="progress-text" class="text-dark fw-bold">0%</small>
                        </div>
                        <div class="progress" style="height: 8px;">
                            <div id="app-progress" class="progress-bar bg-dark transition-width" role="progressbar" style="width: 0%;"></div>
                        </div>
                    </div>

                    <!-- PANELS CONTAINER -->
                    
                    <!-- Panel 0: Welcome (Added 'welcome-shift' to push it higher up) -->
                    <section class="step-panel panel welcome-shift">
                        <h1 class="display-4 fw-bold mb-3">Welcome to the Platform</h1>
                        <p class="lead text-muted mb-4">Let's configure your ideal workspace. This simple process takes less than a minute.</p>
                        <button class="btn btn-dark btn-lg px-5 shadow-sm" onclick="goNext()">Start Setup</button>
                    </section>

                    <!-- Panel 1 -->
                    <section class="step-panel panel d-none">
                        <h3 class="mb-4">What is your primary goal?</h3>
                        <div class="d-grid gap-3 mb-4">
                            <button class="btn btn-outline-dark text-start py-3 px-4 fw-bold" onclick="goNext()">Performance Tuning</button>
                            <button class="btn btn-outline-dark text-start py-3 px-4 fw-bold" onclick="goNext()">Conversion Growth</button>
                        </div>
                        <button class="btn btn-link text-muted px-0 text-decoration-none" onclick="goBack()">← Back</button>
                    </section>

                    <!-- Panel 2 -->
                    <section class="step-panel panel d-none">
                        <h3 class="mb-4">Name your workspace</h3>
                        <div class="mb-4">
                            <label for="workspaceName" class="form-label text-muted">Workspace or Project Name</label>
                            <input type="text" class="form-control form-control-lg" id="workspaceName" placeholder="e.g., Alpha Project">
                        </div>
                        <button class="btn btn-dark py-3 px-5 me-3" onclick="goNext()">Continue</button>
                        <button class="btn btn-link text-muted px-0 text-decoration-none" onclick="goBack()">← Back</button>
                    </section>

                    <!-- Panel 3 -->
                    <section class="step-panel panel d-none">
                        <h3 class="mb-4">Select your industry</h3>
                        <div class="mb-4">
                            <select class="form-select form-select-lg" aria-label="Industry Select">
                                <option selected disabled>Choose an option...</option>
                                <option value="1">Technology & Software</option>
                                <option value="2">E-Commerce & Retail</option>
                                <option value="3">Healthcare & Medical</option>
                            </select>
                        </div>
                        <button class="btn btn-dark py-3 px-5 me-3" onclick="goNext()">Continue</button>
                        <button class="btn btn-link text-muted px-0 text-decoration-none" onclick="goBack()">← Back</button>
                    </section>

                    <!-- Panel 4 -->
                    <section class="step-panel panel d-none">
                        <h3 class="mb-4">Estimated project timeline</h3>
                        <div class="mb-4">
                            <label for="timelineRange" class="form-label text-muted">Months: <span id="rangeVal" class="fw-bold text-dark">6</span></label>
                            <input type="range" class="form-range" min="1" max="12" step="1" value="6" id="timelineRange" oninput="document.getElementById('rangeVal').innerText = this.value">
                        </div>
                        <button class="btn btn-dark py-3 px-5 me-3" onclick="goNext()">See Results</button>
                        <button class="btn btn-link text-muted px-0 text-decoration-none" onclick="goBack()">← Back</button>
                    </section>

                    <!-- Panel 5: Results -->
                    <section class="step-panel panel d-none">
                        <h1 class="display-5 fw-bold text-success mb-3">Setup Complete!</h1>
                        <p class="lead text-muted mb-5">Your customized environment is ready to go based on your inputs.</p>
                        <button class="btn btn-outline-dark px-5 py-2 me-3 shadow-sm" onclick="routeToPanel(0)">Start Over</button>
                        <button class="btn btn-link text-muted px-0 text-decoration-none" onclick="goBack()">← Back</button>
                    </section>

                </div>
            </div>
        </div>
    </main>

    <!-- Persistent Footer -->
    <footer class="bg-dark text-white py-3 position-relative z-3 mt-auto">
        <div class="container-fluid px-4">
            <small>&copy; 2026 BrandLogo. Built with scalable architecture.</small>
        </div>
    </footer>

    <script src="app.js"></script>
</body>
</html>




/* Core Layout */
body {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  margin: 0;
}

.app-wrapper {
  flex: 1; 
  overflow: hidden; 
}

/* Base left-spacing */
.content-offset {
  padding-left: 220px;
}

/* 
* This new class shifts ONLY the welcome text UP vertically.
* By pushing it up 12vh, it avoids the widest part of the donut perfectly.
*/
.welcome-shift {
  transform: translateY(-12vh);
}

/* Utilities */
.transition-width { transition: width 0.6s cubic-bezier(0.25, 1, 0.5, 1); }
.transition-opacity { transition: opacity 0.4s ease; }
.opacity-0 { opacity: 0; pointer-events: none; }

.panel {
  animation: slideUpFade 0.4s cubic-bezier(0.25, 1, 0.5, 1) forwards;
}

@keyframes slideUpFade {
  from { opacity: 0; transform: translateY(15px) translateX(0); }
  /* We ensure translate uses base formatting so it doesn't conflict with .welcome-shift */
  to { opacity: 1; }
}

/* --- HERO ANIMATIONS (Welcome Page) --- */
.shape-container {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none; 
  transition: opacity 0.5s ease;
}

/* Donut perfectly aligned to vertical center */
.half-donut {
  position: absolute;
  width: 400px;
  height: 400px;
  border: 70px solid #000;
  border-radius: 50%;
  left: -200px; 
  top: -500px; 
  animation: dropPerpendicular 1s cubic-bezier(0.25, 1, 0.5, 1) forwards;
}

@keyframes dropPerpendicular {
  to { 
      top: 50%; /* Exact center of the screen */
      transform: translateY(-50%); /* Pulls it up by half its own height */
  }
}

/* Quarter Circle - Much slower, smoother fade in */
.quarter-circle {
  position: absolute;
  width: 150px;
  height: 150px;
  background-color: #000;
  border-radius: 0 0 0 150px;
  top: 0;
  right: 0;
  opacity: 0;
  
  /* Changed from 1s to 2.5s for a longer fade */
  animation: fadeInQuarter 2.5s ease-in-out forwards;
  animation-delay: 0.4s;
}

@keyframes fadeInQuarter {
  to { opacity: 1; }
}

.hero-image {
  position: absolute;
  bottom: 0; 
  left: 45%; 
  transform: translateX(-50%) translateY(100%); 
  width: 500px;  
  height: 160px; 
  object-fit: cover; 
  border-radius: 16px 16px 0 0; 
  opacity: 0;
  animation: slideUpImage 1s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  animation-delay: 0.3s;
}

@keyframes slideUpImage {
  to { transform: translateX(-50%) translateY(0); opacity: 1; }
}

/* --- BOTTOM RIGHT SPIRAL LOADER --- */
.bottom-right-arcs {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 300px; 
  height: 300px;
  pointer-events: none;
}

.draw-arc {
  fill: none;
  stroke: #000;
  stroke-width: 4; 
  stroke-linecap: round;
  stroke-dasharray: 100;
  stroke-dashoffset: 100; 
  /* The animation is now hardcoded here. 
     JS will clone the container to replay it */
  animation: drawPath 1.2s ease-in-out forwards;
}

.arc-1 { animation-delay: 0s; }
.arc-2 { animation-delay: 0.15s; }
.arc-3 { animation-delay: 0.3s; }
.arc-4 { animation-delay: 0.45s; }

@keyframes drawPath {
  to { stroke-dashoffset: 0; }
}

/* Responsive Adjustments */
@media (max-width: 992px) {
  .content-offset { padding-left: 150px; }
  .half-donut { width: 300px; height: 300px; border-width: 50px; left: -150px; }
  .hero-image { left: 50%; }
}

@media (max-width: 768px) {
  .content-offset { padding-left: 20px; }
  .half-donut { opacity: 0.1; } 
  .welcome-shift { transform: translateY(-5vh); } /* Less shift on mobile */
  .hero-image { width: 320px; height: 120px; left: 50%; }
  .bottom-right-arcs { width: 200px; height: 200px; }
}




/**
 * APP STATE VARIABLES
 */
let currentIndex = 0;
const panels = document.querySelectorAll('.step-panel');
const totalQuestions = panels.length - 2; 

/**
 * NAVIGATION LOGIC
 */
function goNext() {
    if (currentIndex < panels.length - 1) {
        routeToPanel(currentIndex + 1);
    }
}

function goBack() {
    if (currentIndex > 0) {
        routeToPanel(currentIndex - 1);
    }
}

/**
 * THE ROUTER 
 */
function routeToPanel(targetIndex) {
    currentIndex = targetIndex;

    // 1. Show the correct panel, hide the rest
    panels.forEach((panel, index) => {
        if (index === currentIndex) {
            panel.classList.remove('d-none');
        } else {
            panel.classList.add('d-none');
        }
    });

    // 2. Determine state flags
    const isWelcomeScreen = (currentIndex === 0);
    const isResultsScreen = (currentIndex === panels.length - 1);

    // 3. Delegate to specific update functions
    updateHeroImages(isWelcomeScreen);
    updateProgressBar(currentIndex, isWelcomeScreen, isResultsScreen);
    reanimateSpiral();
}

/**
 * PROGRESS BAR LOGIC 
 */
function updateProgressBar(index, isWelcome, isResult) {
    const progressContainer = document.getElementById('progress-container');
    const progressBar = document.getElementById('app-progress');
    const progressText = document.getElementById('progress-text');

    if (isWelcome) {
        progressContainer.classList.add('opacity-0');
        progressBar.style.width = '0%';
        progressText.innerText = '0%';
    } else {
        progressContainer.classList.remove('opacity-0');
        let percentage = 0;
        
        if (isResult) {
            percentage = 100;
        } else {
            percentage = (index / totalQuestions) * 100;
        }

        progressBar.style.width = `${percentage}%`;
        progressText.innerText = `${Math.round(percentage)}%`;
    }
}

/**
 * IMAGE VISIBILITY LOGIC 
 */
function updateHeroImages(isWelcome) {
    const heroAnimations = document.getElementById('hero-animations');
    if (isWelcome) {
        heroAnimations.style.opacity = '1';
    } else {
        heroAnimations.style.opacity = '0';
    }
}

/**
 * SPIRAL ANIMATION TRIGGER (Bulletproof Method)
 * By cloning the HTML element and replacing the old one, we trick the browser 
 * into thinking it is a brand new element, guaranteeing the CSS animation replays.
 */
function reanimateSpiral() {
    const container = document.getElementById('spiral-container');
    
    // Check if container exists to prevent errors
    if (container) {
        // Clone the entire SVG container
        const clone = container.cloneNode(true);
        // Replace the old one in the DOM with the fresh clone
        container.parentNode.replaceChild(clone, container);
    }
}

// Initialize the application on page load
routeToPanel(0);
