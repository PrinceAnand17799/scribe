<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Interactive Onboarding</title>
    
    <!-- Bootstrap 5 for layout utilities -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- Persistent Header -->
    <header class="navbar bg-white shadow-sm border-bottom position-relative z-3">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold text-dark" href="#">BrandLogo</a>
        </div>
    </header>

    <!-- Main Workspace -->
    <main class="app-wrapper position-relative bg-light d-flex flex-column">
        
        <!-- Progress Bar (Left aligned, hidden on Welcome screen) -->
        <div id="progress-container" class="container-fluid px-4 mt-4 z-3 transition-opacity opacity-0">
            <div class="row">
                <div class="col-12 col-md-6 col-lg-5">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-muted fw-bold">Setup Progress</small>
                        <small id="progress-text" class="text-dark fw-bold">0%</small>
                    </div>
                    <div class="progress" style="height: 8px;">
                        <div id="app-progress" class="progress-bar bg-dark transition-width" role="progressbar" style="width: 0%;"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- BACKGROUND ANIMATIONS -->

        <!-- 1. The persistent circular lines (Scaled down to 300x300) -->
        <div class="bottom-right-arcs z-1">
            <svg viewBox="0 0 500 500" class="w-100 h-100">
                <path d="M 20 500 A 480 480 0 0 1 500 20" class="draw-arc arc-1" pathLength="100" />
                <path d="M 100 500 A 400 400 0 0 1 500 100" class="draw-arc arc-2" pathLength="100" />
                <path d="M 180 500 A 320 320 0 0 1 500 180" class="draw-arc arc-3" pathLength="100" />
                <path d="M 260 500 A 240 240 0 0 1 500 260" class="draw-arc arc-4" pathLength="100" />
            </svg>
        </div>

        <!-- 2. Hero Elements (Only visible on Welcome Screen) -->
        <div id="hero-animations" class="shape-container z-1">
            <div class="shape half-donut"></div>
            <div class="shape quarter-circle"></div>
            
            <!-- Wide, short elderly couple image -->
            <img src="https://images.unsplash.com/photo-1538356111053-748a48e1acb8?auto=format&fit=crop&w=800&h=250&q=80" alt="Elderly Couple" class="hero-image shadow-lg">
        </div>

        <!-- INTERACTIVE PANELS -->
        <div class="container-fluid px-4 flex-grow-1 d-flex flex-column z-2 mt-4">
            
            <!-- Panel 0: Welcome 
                 'welcome-content' class guarantees it sits right next to the donut with spacing -->
            <section id="panel-welcome" class="panel row mt-5">
                <div class="col-12 col-md-8 col-lg-6 welcome-content">
                    <h1 class="display-4 fw-bold mb-3">Welcome to the Platform</h1>
                    <p class="lead text-muted mb-4">Let's configure your ideal workspace. This simple process takes less than a minute.</p>
                    <button class="btn btn-dark btn-lg px-5 shadow-sm" onclick="goToNextStep()">Start Setup</button>
                </div>
            </section>

            <!-- Question Panels -->
            
            <!-- Panel 1: Buttons -->
            <section id="panel-q1" class="panel d-none row">
                <div class="col-12 col-md-6 col-lg-5">
                    <h3 class="mb-4">What is your primary goal?</h3>
                    <div class="d-grid gap-3">
                        <button class="btn btn-outline-dark text-start py-3 px-4 fw-bold" onclick="goToNextStep()">Performance Tuning</button>
                        <button class="btn btn-outline-dark text-start py-3 px-4 fw-bold" onclick="goToNextStep()">Conversion Growth</button>
                    </div>
                </div>
            </section>

            <!-- Panel 2: Text Input -->
            <section id="panel-q2" class="panel d-none row">
                <div class="col-12 col-md-6 col-lg-5">
                    <h3 class="mb-4">Name your workspace</h3>
                    <div class="mb-4">
                        <label for="workspaceName" class="form-label text-muted">Workspace or Project Name</label>
                        <input type="text" class="form-control form-control-lg" id="workspaceName" placeholder="e.g., Alpha Project">
                    </div>
                    <button class="btn btn-dark py-3 px-5" onclick="goToNextStep()">Continue</button>
                </div>
            </section>

            <!-- Panel 3: Dropdown -->
            <section id="panel-q3" class="panel d-none row">
                <div class="col-12 col-md-6 col-lg-5">
                    <h3 class="mb-4">Select your industry</h3>
                    <div class="mb-4">
                        <select class="form-select form-select-lg" aria-label="Industry Select">
                            <option selected disabled>Choose an option...</option>
                            <option value="1">Technology & Software</option>
                            <option value="2">E-Commerce & Retail</option>
                            <option value="3">Healthcare & Medical</option>
                        </select>
                    </div>
                    <button class="btn btn-dark py-3 px-5" onclick="goToNextStep()">Continue</button>
                </div>
            </section>

            <!-- Panel 4: Slider -->
            <section id="panel-q4" class="panel d-none row">
                <div class="col-12 col-md-6 col-lg-5">
                    <h3 class="mb-4">Estimated project timeline</h3>
                    <div class="mb-4">
                        <label for="timelineRange" class="form-label text-muted">Months: <span id="rangeVal" class="fw-bold text-dark">6</span></label>
                        <input type="range" class="form-range" min="1" max="12" step="1" value="6" id="timelineRange" oninput="document.getElementById('rangeVal').innerText = this.value">
                    </div>
                    <button class="btn btn-dark py-3 px-5" onclick="goToNextStep()">See Results</button>
                </div>
            </section>

            <!-- Panel 5: Results -->
            <section id="panel-results" class="panel d-none row">
                <div class="col-12 col-md-6 col-lg-5">
                    <h1 class="display-5 fw-bold text-success mb-3">Setup Complete!</h1>
                    <p class="lead text-muted mb-5">Your customized environment is ready to go based on your inputs.</p>
                    <button class="btn btn-outline-dark px-5 py-2 shadow-sm" onclick="resetApp()">Start Over</button>
                </div>
            </section>

        </div>
    </main>

    <!-- Persistent Footer -->
    <footer class="bg-dark text-white py-3 position-relative z-3 mt-auto">
        <div class="container-fluid px-4">
            <small>&copy; 2026 BrandLogo. Built with clear code.</small>
        </div>
    </footer>

    <script src="app.js"></script>
</body>
</html>






/* Core Layout */
body {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  margin: 0;
}

.app-wrapper {
  flex: 1; 
  overflow: hidden; 
}

/* --- Utilities --- */
.transition-width { transition: width 0.6s cubic-bezier(0.25, 1, 0.5, 1); }
.transition-opacity { transition: opacity 0.4s ease; }
.opacity-0 { opacity: 0; pointer-events: none; }

/* Panel Animation */
.panel {
  animation: slideUpFade 0.5s cubic-bezier(0.25, 1, 0.5, 1) forwards;
}

@keyframes slideUpFade {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}


/* --- HERO ANIMATIONS (Welcome Page) --- */
.shape-container {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none; 
  transition: opacity 0.5s ease;
}

/* Half Donut (Protrudes exactly 200px into the screen) */
.half-donut {
  position: absolute;
  width: 400px;
  height: 400px;
  border: 70px solid #000;
  border-radius: 50%;
  left: -200px; 
  top: -500px; 
  animation: dropPerpendicular 1s cubic-bezier(0.25, 1, 0.5, 1) forwards;
}

@keyframes dropPerpendicular {
  to { top: 40%; transform: translateY(-50%); }
}

/* Welcome Content Spacing */
.welcome-content {
  /* 200px to clear the donut + 40px padding for breathing room */
  padding-left: 240px; 
}

/* Quarter Circle (Top Right) */
.quarter-circle {
  position: absolute;
  width: 150px;
  height: 150px;
  background-color: #000;
  border-radius: 0 0 0 150px;
  top: 0;
  right: 0;
  opacity: 0;
  animation: fadeInQuarter 1s ease-out forwards;
  animation-delay: 0.6s;
}

@keyframes fadeInQuarter {
  to { opacity: 1; }
}

/* Wider, Shorter Hero Image */
.hero-image {
  position: absolute;
  bottom: 0; 
  left: 45%; 
  transform: translateX(-50%) translateY(100%); 
  width: 500px;  
  height: 160px; 
  object-fit: cover; 
  border-radius: 16px 16px 0 0; 
  opacity: 0;
  animation: slideUpImage 1s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  animation-delay: 0.3s;
}

@keyframes slideUpImage {
  to { transform: translateX(-50%) translateY(0); opacity: 1; }
}


/* --- DRAWING ARCS (Bottom Right Spiral) --- */
.bottom-right-arcs {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 300px; /* Reduced to match previous spiral size */
  height: 300px;
  pointer-events: none;
}

/* SVG Line Styles */
.draw-arc {
  fill: none;
  stroke: #000;
  stroke-width: 4; /* Slightly thicker stroke since the container is smaller */
  stroke-linecap: round;
  
  /* Pushes line entirely out of view */
  stroke-dasharray: 100;
  stroke-dashoffset: 100; 
  
  /* Smooth, uniform loader easing */
  animation: drawPath 1.2s ease-in-out forwards;
}

/* Tighter delays for a coordinated "loading wave" effect */
.arc-1 { animation-delay: 0s; }
.arc-2 { animation-delay: 0.15s; }
.arc-3 { animation-delay: 0.3s; }
.arc-4 { animation-delay: 0.45s; }

@keyframes drawPath {
  to { stroke-dashoffset: 0; }
}

/* Mobile Adjustments */
@media (max-width: 768px) {
  .half-donut { width: 250px; height: 250px; border-width: 40px; left: -125px; }
  
  /* Mobile donut protrudes 125px, leave 25px gap */
  .welcome-content { padding-left: 150px; }
  
  .hero-image { width: 320px; height: 120px; left: 50%; }
  .bottom-right-arcs { width: 200px; height: 200px; }
}






/**
 * APP STATE VARIABLES
 */
let currentStep = 0;           
const totalQuestions = 4;      

/**
 * Moves the user forward by 1 step
 */
function goToNextStep() {
    currentStep++; 
    updateUI();                    
}

/**
 * Resets back to the Welcome screen
 */
function resetApp() {
    currentStep = 0;
    updateUI();
}

/**
 * CORE LOGIC (The Router)
 */
function updateUI() {
    
    // 1. Hide ALL panels to reset the view
    const allPanels = document.querySelectorAll('.panel');
    allPanels.forEach(panel => {
        panel.classList.add('d-none');
    });

    // 2. DOM Elements to manipulate
    const progressContainer = document.getElementById('progress-container');
    const progressBar = document.getElementById('app-progress');
    const progressText = document.getElementById('progress-text');
    const heroAnimations = document.getElementById('hero-animations');

    // 3. Routing Logic
    if (currentStep === 0) {
        
        // --- WELCOME SCREEN ---
        document.getElementById('panel-welcome').classList.remove('d-none');
        
        progressContainer.classList.add('opacity-0'); 
        progressBar.style.width = '0%';               
        heroAnimations.style.opacity = '1';           
        
    } else if (currentStep >= 1 && currentStep <= totalQuestions) {
        
        // --- QUESTIONNAIRE SCREENS ---
        document.getElementById('panel-q' + currentStep).classList.remove('d-none');
        
        progressContainer.classList.remove('opacity-0'); 
        heroAnimations.style.opacity = '0';              
        
        // Math (e.g., Step 2 out of 4 = 50%)
        const percentage = (currentStep / totalQuestions) * 100;
        
        progressBar.style.width = percentage + '%';
        progressText.innerText = Math.round(percentage) + '%';
        
    } else {
        
        // --- RESULTS SCREEN ---
        document.getElementById('panel-results').classList.remove('d-none');
        
        progressContainer.classList.remove('opacity-0');
        heroAnimations.style.opacity = '0';
        
        progressBar.style.width = '100%';
        progressText.innerText = '100%';
    }

    // 4. Re-trigger the bottom-right spiral animation
    reanimateSpiral();
}

/**
 * ANIMATION RESET TRICK
 * Forces the browser to replay the CSS drawing animation on the SVG lines.
 */
function reanimateSpiral() {
    // Grab all 4 SVG paths
    const arcs = document.querySelectorAll('.draw-arc');
    
    arcs.forEach(arc => {
        // Step A: Strip the animation away
        arc.style.animation = 'none';
        
        // Step B: Ask for the element's width. 
        // The browser *has* to recalculate the screen to give us this number.
        // This is called forcing a "DOM Reflow".
        void arc.offsetWidth; 
        
        // Step C: Give the animation back. The browser treats it as brand new and plays it.
        arc.style.animation = null; 
    });
}

// Ensure the UI aligns with state on page load
updateUI();
