/**
 * HEALTHCARE ESTIMATOR SYSTEM ARCHITECTURE
 * Clean, readable, and strictly separated functionality.
 */
const appLogic = (function() {
    
    // Core State Variables
    let currentIndex = 0;
    let panels = [];
    let modalInstance = null;
    let totalQuestions = 0;

    /**
     * INIT: Main bootup function attached to DOM load.
     */
    function init() {
        // Cache DOM elements
        panels = document.querySelectorAll('.step-panel');
        totalQuestions = document.querySelectorAll('.question-block').length;
        
        // Attach input listener events to all question panels to handle real-time validation checks
        bindValidationListeners();

        // Display initial panel
        routeToPanel(0);
    }

    /**
     * VALIDATION BINDING: Listens for any change on required inputs and toggles the Next button
     */
    function bindValidationListeners() {
        // Find all panels that represent questions (skipping welcome and results)
        panels.forEach((panel, index) => {
            if (index > 0 && index < panels.length - 1) {
                
                // Get the specific Next button for this panel
                const nextBtn = panel.querySelector('.validation-next-btn');
                
                // Get all inputs (text, number, radio) inside this panel
                const inputs = panel.querySelectorAll('input');
                
                // Whenever a user types or clicks a radio button, re-check the form
                inputs.forEach(input => {
                    input.addEventListener('input', () => {
                        validatePanel(panel, nextBtn);
                    });
                    // For radio buttons specifically, 'change' is often more reliable
                    input.addEventListener('change', () => {
                        validatePanel(panel, nextBtn);
                    });
                });
            }
        });
    }

    /**
     * VALIDATION LOGIC: Checks if all required fields in the current panel are satisfied
     */
    function validatePanel(panel, nextBtn) {
        if (!nextBtn) return;

        let allValid = true;

        // Step 1: Check number/text fields
        const textInputs = panel.querySelectorAll('input[type="text"], input[type="number"]');
        textInputs.forEach(input => {
            if (input.hasAttribute('required')) {
                // If it fails standard HTML5 validity (e.g., min/max bounds, or is empty)
                if (!input.checkValidity()) {
                    allValid = false;
                    // Show bootstrap error styling
                    input.classList.add('is-invalid');
                } else {
                    input.classList.remove('is-invalid');
                }
            }
        });

        // Step 2: Check radio button groups. 
        // We must ensure that for every unique 'name' attribute in the panel, at least one is checked.
        const radioInputs = panel.querySelectorAll('input[type="radio"]');
        if (radioInputs.length > 0) {
            // Group radio inputs by their 'name' attribute to check each group individually
            const radioGroups = {};
            radioInputs.forEach(radio => {
                if (!radioGroups[radio.name]) {
                    radioGroups[radio.name] = [];
                }
                radioGroups[radio.name].push(radio);
            });

            // Iterate over each named group. If any group has zero checked options, panel is invalid.
            for (const groupName in radioGroups) {
                const group = radioGroups[groupName];
                const isGroupRequired = group[0].hasAttribute('required');
                
                if (isGroupRequired) {
                    const isAnyChecked = group.some(radio => radio.checked);
                    if (!isAnyChecked) {
                        allValid = false;
                    }
                }
            }
        }

        // Finalize: Enable or disable the button based on the evaluation
        nextBtn.disabled = !allValid;
    }


    /**
     * API MODULE 1: Sends partial data after user finishes Q2
     */
    function sendPartialDataPayload() {
        const partialData = {
            currentAge: document.getElementById('q1_age').value || null,
            expectedRetirementAge: document.getElementById('q2_retire_age').value || null,
            timestamp: new Date().toISOString()
        };
        
        console.log(">>> [API TRANSMISSION 1] Sending partial onboarding data...");
        console.log("POST /api/v1/onboarding/partial", partialData);

        /* // Future implementation ready:
        fetch('/api/v1/onboarding/partial', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(partialData)
        }).catch(err => console.error(err));
        */
    }

    /**
     * API MODULE 2: Sends complete JSON payload and updates UI calculation on the final step
     */
    function submitFinalEstimateData() {
        const fullPayload = {};
        const inputs = document.querySelectorAll('input');
        
        // Harvest all responses globally
        inputs.forEach(input => {
            if (input.type === 'radio' && input.checked) {
                fullPayload[input.name] = input.value;
            } else if ((input.type === 'number' || input.type === 'text') && input.value) {
                fullPayload[input.name] = input.value;
            }
        });

        // Log the final consolidated JSON string as requested
        console.log(">>> [API TRANSMISSION 2] Sending complete response JSON...");
        console.log(JSON.stringify(fullPayload, null, 2));

        // -- Business Logic Calculation -- 
        // Simple demonstrative pricing calculation based on user selections
        let calculatedBase = 3200; 
        if (fullPayload['q5_health'] === 'Fair' || fullPayload['q5_health'] === 'Poor') calculatedBase += 1250;
        if (fullPayload['q9_rx_cost'] === '5000 or more') calculatedBase += 950;

        // Apply dynamically to the final Results DOM rendering frame
        const costDisplay = document.getElementById('dynamic-cost-display');
        if (costDisplay) {
            costDisplay.innerText = `$${calculatedBase.toLocaleString()} / year`;
        }
    }


    /**
     * CORE ROUTING: Handles transitioning between panels
     */
    function routeToPanel(targetIndex) {
        currentIndex = targetIndex;
        if (!panels.length) return;

        // Toggle display classes
        panels.forEach((panel, index) => {
            if (index === currentIndex) {
                panel.classList.remove('d-none');
            } else {
                panel.classList.add('d-none');
            }
        });

        // Determine application context state
        const isWelcomeScreen = (currentIndex === 0);
        const isResultsScreen = (currentIndex === panels.length - 1);

        // Dispatch visual updates based on state
        updateHeroVisibility(isWelcomeScreen, isResultsScreen);
        updateProgressBar(currentIndex, isWelcomeScreen, isResultsScreen);
        reanimateCanvasElements();
    }


    /**
     * NEXT BUTTON HANDLER: Contains the conditional logic for specific steps
     */
    function handleNext() {
        // Condition: User just finished Step 1 (Current Age)
        if (currentIndex === 1) {
            const currentAgeValue = document.getElementById('q1_age').value;
            sessionStorage.setItem('cachedAgeRegistry', currentAgeValue || 0);
            goNextStandard();
        } 
        
        // Condition: User just finished Step 2 (Retirement Age)
        else if (currentIndex === 2) {
            const retireAgeInput = parseInt(document.getElementById('q2_retire_age').value, 10);
            
            // Native dispatch of partial API payload
            sendPartialDataPayload();

            // Validate against the 65-year threshold trigger for the modal
            if (retireAgeInput < 65 && !isNaN(retireAgeInput)) {
                const modalElement = document.getElementById('ageWarningModal');
                if (modalElement) {
                    if (!modalInstance) {
                        modalInstance = new bootstrap.Modal(modalElement);
                    }
                    modalInstance.show();
                } else {
                    goNextStandard();
                }
            } else {
                goNextStandard();
            }
        } 
        
        // Condition: User just clicked 'Show me my Estimate' on the final question
        else if (currentIndex === panels.length - 2) {
            submitFinalEstimateData();
            goNextStandard();
        } 
        
        // Condition: Standard advancement for all other typical steps
        else {
            goNextStandard();
        }
    }

    function goNextStandard() {
        if (currentIndex < panels.length - 1) {
            routeToPanel(currentIndex + 1);
        }
    }

    function goBack() {
        if (currentIndex > 0) {
            routeToPanel(currentIndex - 1);
        }
    }

    // Called exclusively from inside the Bootstrap Modal "OK" button
    function proceedFromModal() {
        if (modalInstance) modalInstance.hide();
        goNextStandard();
    }


    /**
     * PROGRESS BAR LOGIC: Dynamically counts HTML .question-block elements
     */
    function updateProgressBar(panelIndex, isWelcome, isResult) {
        const progressContainer = document.getElementById('progress-container');
        const progressBar = document.getElementById('app-progress');
        const progressText = document.getElementById('progress-text');

        if (!progressContainer || !progressBar || !progressText) return;

        // Hide progress bar totally on Welcome (0) or Results (End)
        if (isWelcome || isResult) {
            progressContainer.classList.add('opacity-0');
            progressBar.style.width = '0%';
        } else {
            progressContainer.classList.remove('opacity-0');
            
            let questionsAnswered = 0;
            // Iterate through panels previously seen and count how many total questions have been cleared
            for (let i = 1; i < panelIndex; i++) {
                questionsAnswered += panels[i].querySelectorAll('.question-block').length;
            }
            
            const percentage = (questionsAnswered / totalQuestions) * 100;

            progressText.innerText = `${questionsAnswered} out of ${totalQuestions} questions answered`;
            progressBar.style.width = `${percentage}%`;
        }
    }


    /**
     * ARTWORK CONTROLLER: Switches background objects depending on the active view
     */
    function updateHeroVisibility(isWelcome, isResult) {
        const heroAnimations = document.getElementById('hero-animations');
        const onboardingContainer = document.getElementById('onboarding-flow-container');
        const welcomeGradient = document.querySelector('.welcome-blue-gradient');
        const welcomeImg = document.getElementById('welcome-footer-img');

        if (isWelcome) {
            // Restore all welcoming visuals
            if (onboardingContainer) onboardingContainer.classList.remove('d-none');
            if (heroAnimations) heroAnimations.style.opacity = '1';
            if (welcomeGradient) welcomeGradient.style.opacity = '1';
            if (welcomeImg) welcomeImg.style.display = 'block';
            
        } else if (isResult) {
            // Completely hide the onboarding structure and entry visuals
            if (onboardingContainer) onboardingContainer.classList.add('d-none');
            if (heroAnimations) heroAnimations.style.opacity = '0';
            if (welcomeGradient) welcomeGradient.style.opacity = '0';
            if (welcomeImg) welcomeImg.style.display = 'none';
            
        } else {
            // Questionnaire Phase: Show flow, hide background visuals
            if (onboardingContainer) onboardingContainer.classList.remove('d-none');
            if (heroAnimations) heroAnimations.style.opacity = '0';
        }
    }


    /**
     * CANVAS UTILITY: Forces the browser to replay the SVG animation loop natively
     */
    function reanimateCanvasElements() {
        const container = document.getElementById('spiral-container');
        if (container) {
            const clone = container.cloneNode(true);
            container.parentNode.replaceChild(clone, container);
        }
    }

    /**
     * RESET MODULE: Wipes all form data and resets user to Question 1
     */
    function resetApp() {
        sessionStorage.removeItem('cachedAgeRegistry');
        
        // Strip data from all form fields
        document.querySelectorAll('input').forEach(input => {
            if (input.type === 'radio') input.checked = false;
            if (input.type === 'number' || input.type === 'text') input.value = '';
            input.classList.remove('is-invalid');
        });
        
        // Re-lock all buttons
        document.querySelectorAll('.validation-next-btn').forEach(btn => btn.disabled = true);
        
        // Jump to Question 1
        routeToPanel(1);
    }

    // Attach primary initialization hook to DOM readiness
    window.addEventListener('DOMContentLoaded', init);

    // Expose functional endpoints to the global window for HTML onclick handling
    return {
        handleNext,
        goBack,
        proceedFromModal,
        resetApp
    };

})();
